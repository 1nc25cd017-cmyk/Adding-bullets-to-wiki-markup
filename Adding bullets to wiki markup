def collatz_sequence(n):
    sequence = [n]   # start with the given number
    while n != 1:
        if n % 2 == 0:   # even
            n = n // 2
        else:            # odd
            n = 3 * n + 1
        sequence.append(n)
    return sequence

# Example usage
num = int(input("Enter a positive integer: "))
print("Collatz sequence:", collatz_sequence(num))
